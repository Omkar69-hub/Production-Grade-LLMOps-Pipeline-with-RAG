# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Leave empty to use the built-in fallback (returns raw retrieved chunks)
OPENAI_API_KEY=

# gpt-3.5-turbo | gpt-4 | gpt-4o
LLM_MODEL=gpt-3.5-turbo

# ─── Embeddings ──────────────────────────────────────────────────────────────
# HuggingFace model name used for embedding documents
EMBED_MODEL=all-MiniLM-L6-v2

# ─── Vector Store ────────────────────────────────────────────────────────────
VECTORSTORE_PATH=vectorstore

# Chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ─── AWS / S3 ────────────────────────────────────────────────────────────────
# Leave blank to disable S3 integration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ─── App ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
