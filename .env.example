# ─── OpenAI (optional — leave empty for retrieval-only mode) ──────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-3.5-turbo

# ─── Embeddings (local, no API key required) ──────────────────────────────────
EMBED_MODEL=all-MiniLM-L6-v2

# ─── Vector Store ─────────────────────────────────────────────────────────────
VECTORSTORE_PATH=vectorstore
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ─── Hybrid Search Weights ────────────────────────────────────────────────────
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3
RERANKER_TOP_K=10
FINAL_TOP_K=4

# ─── AWS / S3 (leave blank to disable) ───────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Run to generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-output-of-python-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── First-Run Admin Credentials ─────────────────────────────────────────────
# Used ONLY when the users table is empty (very first startup).
# ⚠️  Set a strong password (min 8 chars). Change it immediately after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password-min-8-chars

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Redis (optional cache) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false
CACHE_TTL_SECONDS=300

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — no setup required):
DATABASE_URL=sqlite+aiosqlite:///./rag_llmops.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ragdb

# ─── MLflow (optional) ────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=rag-llmops
MLFLOW_ENABLED=false

# ─── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
CORS_ORIGINS=*
API_PREFIX=/api/v1
